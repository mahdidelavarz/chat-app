{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev:postgres": "cross-env NODE_ENV=development dotenv -e .env.postgres.local -- ts-node src/server.ts",
    "dev:sqlserver": "cross-env NODE_ENV=development dotenv -e .env.sqlserver.local -- ts-node src/server.ts",
    "dev": "npm run dev:postgres",
    "build": "tsc",
    "start": "node dist/server.js",
    "start:postgres": "cross-env NODE_ENV=production dotenv -e .env.postgres.local -- node dist/server.js",
    "start:sqlserver": "cross-env NODE_ENV=production dotenv -e .env.sqlserver.local -- node dist/server.js",
    "migration:run:postgres": "cross-env NODE_ENV=development dotenv -e .env.postgres.local -- ts-node node_modules/typeorm/cli.js migration:run",
    "migration:run:sqlserver": "cross-env NODE_ENV=development dotenv -e .env.sqlserver.local -- ts-node node_modules/typeorm/cli.js migration:run"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mssql": "^12.5.0",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "socket.io": "^4.8.3",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
