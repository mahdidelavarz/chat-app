# Server
PORT=5000
NODE_ENV=development

# Database - SQL Server
DB_TYPE=mssql
DB_HOST=localhost
DB_PORT=1433
DB_USER=node_user
DB_PASSWORD=123
DB_DATABASE=chatDb
DB_SYNCHRONIZE=true
DB_LOGGING=true

# SQL Server specific (optional)
DB_OPTIONS_ENCRYPT=false
DB_OPTIONS_TRUST_SERVER_CERTIFICATE=true

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_EXPIRES_IN=7d

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://172.16.2.99:3000

# Frontend URLs
FRONTEND_URL=http://localhost:3000